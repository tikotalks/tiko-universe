{
  "name": "tiko-universe",
  "private": true,
  "version": "0.0.0",
  "description": "API-first Tiko platform with web, iOS, and Android clients.",
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*/web",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "check": "npm run scaffold:check && npm run lint && npm run typecheck && npm run test",
    "generate:app-configs": "node tools/generate-app-configs.mjs",
    "generate:colors": "node tools/generate-tiko-colors.mjs",
    "generate:talk-seeds": "node tools/generate-talk-seeds.mjs",
    "prebuild": "npm run generate:colors",
    "scaffold:check": "node tools/check-placeholders.mjs",
    "lint": "oxlint .",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:contracts": "vitest run tests/identity-api.test.ts tests/app-api.test.ts tests/generation-api.test.ts tests/atlas-api.test.ts tests/testing-contract.test.ts",
    "test:services": "npm run test:contracts",
    "build": "npm run build --workspaces --if-present",
    "android:list": "node tools/android-wrappers.mjs list",
    "android:sync": "node tools/android-wrappers.mjs sync",
    "android:build": "node tools/android-wrappers.mjs build-android",
    "audit:doctrine": "node tools/check-doctrine.mjs",
    "deploy:dry-run:tts": "npm --workspace @tiko-worker/tts-api run deploy:dry-run",
    "deploy:dry-run:generation": "npm --workspace @tiko-worker/generation-api run deploy:dry-run",
    "deploy:dry-run:sentence": "npm --workspace @tiko-worker/sentence-api run deploy:dry-run"
  },
  "dependencies": {
    "@sil/ui": "^2.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "bemm": "^1.4.0",
    "jsdom": "^27.2.0",
    "open-icon": "^1.1.9",
    "sass": "^1.94.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "vue": "^3.5.24",
    "vue-tsc": "^3.1.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "miniflare": "^4.20260611.0",
    "oxlint": "^1.69.0",
    "wrangler": "^4.98.0"
  }
}
