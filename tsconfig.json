{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@tiko/data": ["packages/data/src/index.ts"],
      "@tiko/data/*": ["packages/data/src/*"],
      "@tiko/identity": ["packages/identity/src/index.ts"],
      "@tiko/identity/*": ["packages/identity/src/*"],
      "@tiko/i18n": ["packages/i18n/src/index.ts"],
      "@tiko/i18n/*": ["packages/i18n/src/*"],
      "@tiko/media": ["packages/media/src/index.ts"],
      "@tiko/media/*": ["packages/media/src/*"],
      "@tiko/testing": ["packages/testing/src/index.ts"],
      "@tiko/testing/*": ["packages/testing/src/*"],
      "@tiko/ui": ["packages/ui/src/index.ts"],
      "@tiko/ui/*": ["packages/ui/src/*"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.vue",
    "packages/**/*.ts",
    "packages/**/*.vue",
    "workers/**/*.ts",
    "tests/**/*.ts",
    "env.d.ts"
  ],
  "exclude": [
    "**/e2e/**",
    "**/android/**"
  ]
}
